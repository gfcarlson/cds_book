@AbapCatalog.sqlViewName: 'ZHIEMPREL02'

define view ZHI_EmployeeRelation02
  as select from ZHP_EmployeeRelation

  association [0..1] to ZHI_EmployeeRelation02 as _Manager  on $projection.Manager  = _Manager.Employee
  association [0..1] to ZHI_Employee           as _Employee on $projection.Employee = _Employee.Employee

{
  Employee,
  Manager,
  _Manager,
  _Employee
}
where
      DemoSet = '1'
  or  DemoSet = '2'
