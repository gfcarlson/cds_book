union all select from t000 { '0014' as Employee, 'Nils'       as EmployeeName, 'M' as Gender, 100 as PartTimePercent, 95 as Score  } where mandt = '000'
union all select from t000 { '0015' as Employee, 'Olga'       as EmployeeName, 'F' as Gender, 100 as PartTimePercent, 49 as Score  } where mandt = '000'
union all select from t000 { '0016' as Employee, 'Patrick'    as EmployeeName, 'M' as Gender, 100 as PartTimePercent, 85 as Score  } where mandt = '000'
